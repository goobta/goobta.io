---
import Base from '../layouts/Base.astro';
---

<Base title="goobta.io">
  <main>
    <h1>goobta.io</h1>
    <p>Something is coming.</p>
  </main>
</Base>

<style>
  main {
    min-height: 100dvh;
    display: grid;
    place-content: center;
    gap: 0.5rem;
    text-align: center;
    padding: 2rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    letter-spacing: -0.03em;
  }

  p {
    margin: 0;
    color: var(--muted);
    font-size: 1.125rem;
  }
</style>
